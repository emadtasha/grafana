# Copy this file to .env and adjust values before running `docker compose up`

# Public IP of the EC2 instance this stack is deployed on
EC2_PUBLIC_IP=100.58.158.7

# Grafana admin password (default is "admin" if unset -- change this!)
GRAFANA_ADMIN_PASSWORD=changeme123

# How often (seconds) the host filesystem is scanned by Trivy
TRIVY_HOST_SCAN_INTERVAL=3600
